{
  "name": "biko",
  "version": "1.0.0",
  "private": true,
  "description": "Bíko - Marketplace de Profissionais de Bairro",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/backend",
    "start": "npm run start --workspace=packages/backend",
    "db:migrate": "npm run db:migrate --workspace=packages/backend",
    "db:migrate:undo": "npm run db:migrate:undo --workspace=packages/backend",
    "db:seed": "npm run db:seed --workspace=packages/backend",
    "db:reset": "npm run db:reset --workspace=packages/backend",
    "install:all": "npm install"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}